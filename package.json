{
  "name": "RickAndMorty",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build-aab": "npx react-native build-android --mode=release",
    "build-apk": "cd android && ./gradlew assembleRelease",
    "eslint": "eslint .",
    "eslint-auto-fix-the-whole-project": "eslint . --fix",
    "install-pods": "cd ios && pod install --repo-update",
    "open-android-studio": "open -a /Applications/Android\\ Studio.app android",
    "open-xcode": "xed -b ios",
    "pod-repo-update": "cd ios && pod repo update",
    "prettier-the-whole-project": "prettier --write '**/*.{css,js,json,jsx,markdown,md,scss,ts,tsx}'",
    "reinstall-node-modules": "rm -rf node_modules && yarn",
    "reinstall-pods": "rm -rf ios/build ios/Pods ios/Podfile.lock && yarn install-pods",
    "reset": "yarn run clean && yarn run setup && yarn run install-pods",
    "reset-full": "yarn run clean && yarn run clean-lockfile && yarn run setup",
    "android": "react-native run-android",
    "run-devices": "yarn run-ios-se && yarn run-ios-14-pro-max && yarn run-ios-13 && yarn run-android",
    "ios": "react-native run-ios",
    "run-ios-15": "npx react-native run-ios --simulator=\"iPhone 15\"",
    "run-ios-15-pro-max": "npx react-native run-ios --simulator=\"iPhone 15 Pro Max\"",
    "lint": "eslint .",
    "test": "jest",
    "setup": "yarn",
    "start": "npx react-native start --reset-cache"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.77.0",
    "react-native-reanimated": "^3.16.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.77.0",
    "@react-native/eslint-config": "0.77.0",
    "@react-native/metro-config": "0.77.0",
    "@react-native/typescript-config": "0.77.0",
    "@types/jest": "^29.5.13",
    "@types/react": "^18.2.6",
    "@types/react-test-renderer": "^18.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "metro-react-native-babel-preset": "^0.77.0",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "18.3.1",
    "typescript": "5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
